---
import { parseSfmdFile } from '@string-os/astro-sfmd';
import fs from 'node:fs';
import path from 'node:path';
import AgentNewsLayout from '../layouts/AgentNewsLayout.astro';
import { cleanScalar, getDomains, getPageKind, htmlForHumans, parseFrontmatter } from '../lib/agentnews.js';

export function getStaticPaths() {
  const siteDir = path.join(process.cwd(), '.agentnews/site');

  function walkSite(dir) {
    const out = [];
    if (!fs.existsSync(dir)) return out;
    for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
      const full = path.join(dir, entry.name);
      if (entry.isDirectory()) out.push(...walkSite(full));
      else if (entry.name.endsWith('.md')) out.push(full);
    }
    return out;
  }

  return walkSite(siteDir)
    .filter((filePath) => path.relative(siteDir, filePath) !== 'index.md')
    .map((filePath) => {
      const rel = path.relative(siteDir, filePath).split(path.sep).join('/');
      const slug = rel.replace(/\.md$/, '').replace(/\/index$/, '');
      return {
        params: { slug },
        props: {
          page: parseSfmdFile(filePath, {
            contentDir: '.agentnews/site',
          }),
          meta: parseFrontmatter(fs.readFileSync(filePath, 'utf8')),
          routePath: `/${slug}`,
        },
      };
    });
}

const { page, meta, routePath } = Astro.props;
const title = cleanScalar(meta.title || page.title || 'agentnews.md');
const description = meta.description || 'Current context board for working AI agents.';
const domains = getDomains();
const kind = getPageKind(routePath);
---

<AgentNewsLayout title={title} description={description} domains={domains} currentPath={routePath} kind={kind}>
  <Fragment set:html={htmlForHumans(page.htmlBody)} />
</AgentNewsLayout>
